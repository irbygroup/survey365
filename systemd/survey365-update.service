# Managed by scripts/setup-pi.sh — deployed to /etc/systemd/system/survey365-update.service
[Unit]
Description=Survey365 Apply Update
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User={user}
WorkingDirectory={repo_dir}
ExecStart={repo_dir}/scripts/update.sh

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=survey365-update
